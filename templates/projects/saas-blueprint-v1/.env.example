ENVIRONMENT=dev                      # dev | prod
LOG_LEVEL=DEBUG                      # DEBUG | INFO
SQL_ECHO=true                        # true | false

POSTGRES_HOST=localhost
POSTGRES_PORT=                       # DEV:5446 | PROD:5444
POSTGRES_USER=saas_blueprint_v1
POSTGRES_PASSWORD=                   # ver 00-variables.md
POSTGRES_DATABASE=                   # DEV:saas_blueprint_v1_dev | PROD:saas_blueprint_v1

REDIS_URL=redis://localhost:<porta>  # DEV:6383 | PROD:6385
QDRANT_URL=http://localhost:<porta>   # DEV:6341 | PROD:6343
RABBITMQ_URL=amqp://guest:guest@localhost:<porta>/  # DEV:5674 | PROD:5675

JWT_SECRET_KEY=                      # gere: python -c "import secrets; print(secrets.token_hex(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BACKEND_PORT=                        # DEV:10010 | PROD:10000
AUTH_PORT=                           # DEV:10110 | PROD:10100
FRONTEND_PORT=                       # DEV:5178 | PROD:5177

AUTH_SERVICE_URL=http://localhost:<AUTH_PORT>
FRONTEND_URL=http://localhost:<FRONTEND_PORT>
BACKEND_CORS_ORIGINS=["http://localhost:<FRONTEND_PORT>"]
