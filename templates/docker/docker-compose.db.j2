name: gus-{{ PROJECT_KEY }}{{ ENV_SUFFIX }}

services:

  # ── PostgreSQL {{ ENV_LABEL_UPPER }} ─────────────────────────────────────────────
  postgres{{ ENV_SUFFIX }}:
    image: postgres:{{ DB_VERSION }}
    container_name: {{ PROJECT_KEY }}-postgres{{ ENV_SUFFIX }}
    environment:
      POSTGRES_DB:       {{ DB_NAME }}
      POSTGRES_USER:     {{ DB_USER }}
      POSTGRES_PASSWORD: {{ DB_PASSWORD }}
      PGDATA:            /var/lib/postgresql/data
      TZ:                {{ TIMEZONE }}
      PGTZ:              {{ TIMEZONE }}
    ports:
      - "{{ DB_PORT }}:5432"
    volumes:
      - postgres_data_{{ ENV_LABEL }}:/var/lib/postgresql/data
    networks:
      - {{ PROJECT_KEY }}-network{{ ENV_SUFFIX }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ DB_USER }} -d {{ DB_NAME }}"]
      interval: 10s
      timeout: 5s
      retries: 5

